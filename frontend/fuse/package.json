{
  "name": "fuse",
  "private": true,
  "version": "0.1.0",
  "description": "FUSE modding runtime for WoT HEAT",
  "author": "AET3RNAL",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@rive-app/canvas": "^2.38.2",
    "@sentry/electron": "^7.13.0",
    "@supabase/supabase-js": "^2.108.2",
    "electron-updater": "^6.8.9",
    "lottie-web": "^5.13.0",
    "mitt": "^3.0.1",
    "motion-v": "^2.3.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "posthog-js": "^1.392.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-bundle-obfuscator": "^1.12.0",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vue-tsc": "^3.3.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "icon": "build/icon.png",
    "appId": "com.heatfuse",
    "productName": "FUSE",
    "protocols": {
      "name": "FUSE",
      "schemes": ["fuse"]
    },
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "resources/fuse.exe",
        "to": "fuse.exe"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
