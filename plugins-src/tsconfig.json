{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@fuse/plugin-sdk": ["../runtime/src/sdk/index.ts"]
    },
    "typeRoots": ["../runtime/node_modules/@types"],
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
