{
  "plugin_id": "heat_ailos_torc",
  "name": "H.E.A.T. AILOS TORC",
  "version": "1.0",
  "author": "AETERNAL",
  "description": "Automatic Indirect Line of Sight is a trajectory correction system for ATGMs",
  "entry": "plugin:HeatAilosTorcPlugin",
  "tags": ["ml", "saclos", "overlay"],
  "optional_dependencies": ["game_memory"],
  "default_config": {
    "mode": "predictor",
    "profile_name": null,

    "calibrated_x": null,
    "calibrated_y": null,
    "origin_x": null,
    "origin_y": null,
    "margin_x": 700,
    "margin_y": 400,
    "image_path": "Ballistic Drop Compensator-01.png",
    "tracking_image_path": "Ballistic Drop Compensator-02.png",
    "tracking_key_name": "q",
    "rf_key_name": "r",
    "ocr_region": null,
    "ocr_enabled": false,
    "ocr_poll_interval_ms": 350,
    "ocr_display_pos": null,
    "input_backend": "sendinput",

    "hud_assets_dir": "assets",
    "hud_name_image": "predictor.png",
    "hud_descriptor_image": "interceptSystem.png",
    "hud_range_image": "range.png",
    "hud_status_image": "status.png",
    "hud_status_idle": "statusIdle.png",
    "hud_status_predict": "statusPredict.png",
    "hud_status_intercept": "statusIntercept.png",
    "hud_designator_predict": "designatorPredict.png",
    "hud_designator_intercept": "designatorIntercept.png",
