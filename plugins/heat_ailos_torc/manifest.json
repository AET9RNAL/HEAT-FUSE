    "pixels_per_degree": 10.0,
    "mouse_sensitivity_scale": 1.0,
    "ml_enabled": true,
    "ml_confidence_threshold": 0.3,
    "ml_online_learning": false,
    "attn_enabled": true,
    "attn_lr": 0.02,
    "attn_n_buckets": 10,
    "torc_quality_weight": 0.5,
    "quick_label_enabled": true,
    "envelope_enabled": true,
    "ql_prompt_pos": null,
    "ql_graph_factors_pos": null,
